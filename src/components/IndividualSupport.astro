---
import { Image } from "astro:assets";
import family from "../assets/images/family.png";
---

<section class="detail-section detail-light" id="individual">
    <div class="container detail-grid">
        <div class="detail-text">
            <p class="section-label">Individual Support</p>

            <h2>Supporting children, young people and families.</h2>

            <p>
                Supporting children, young people and parents through
                educational psychology assessment, therapeutic intervention and
                psychology-informed guidance that builds understanding,
                confidence and emotional wellbeing.
            </p>

            <p>
                Support is tailored to the unique needs of each child and
                family, drawing on evidence-informed psychological approaches to
                understand behaviour, strengthen relationships and promote
                lasting positive change.
            </p>
        </div>

        <div class="detail-image">
            <Image src={family} alt="Family support illustration" />
        </div>
    </div>
</section>
