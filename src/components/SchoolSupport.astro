---
import { Image } from "astro:assets";
import school from "../assets/images/school.png";
---

<section class="detail-section detail-light" id="schools">
    <div class="container detail-grid">
        <div class="detail-image">
            <Image src={school} alt="School support illustration" />
        </div>

        <div class="detail-text">
            <p class="section-label">School Support</p>

            <h2 class="section-title">
                Helping schools create supportive learning environments.
            </h2>
            <p>
                Educational psychology consultation, assessment, staff training,
                wellbeing initiatives and whole-school approaches that promote
                inclusion, belonging and positive relationships.
            </p>

            <p>
                Working collaboratively with teachers, school leaders and
                families, support is tailored to the unique needs of each school
                community, helping create environments where children and young
                people can thrive academically, socially and emotionally.
            </p>
        </div>
    </div>
</section>
