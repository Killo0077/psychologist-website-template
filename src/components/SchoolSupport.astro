---
import { Image } from "astro:assets";
import school from "../assets/images/school.png";
---

<section class="detail-section detail-light" id="schools">
    <div class="container detail-grid">
        <div class="detail-image">
            <Image src={school} alt="School support illustration" />
        </div>

        <div class="detail-text">
            <p class="section-label">School Support</p>

            <h2 class="section-title">
                Helping schools create supportive learning environments.
            </h2>

            <p>
                Working collaboratively with schools to support children's
                emotional wellbeing, resilience and educational development
                through consultation and evidence-based psychological guidance.
            </p>

            <p>
                Together with teachers, parents and school staff, Victoria helps
                build strategies that promote inclusion, confidence and positive
                learning experiences for every student.
            </p>
        </div>
    </div>
</section>
